{
  "description": "fieldwork-flow: session continuity hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check whether /handoff was run during THIS session. If not, use AskUserQuestion to ask: A) run /handoff now, B) skip. If /handoff was already run, end without prompting.",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
